{
  "name": "@colonels-academy/api",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "tsx watch --env-file=../../.env src/index.ts",
    "build": "pnpm --filter @colonels-academy/database run db:generate && tsup --config tsup.config.ts",
    "start": "pnpm --filter @colonels-academy/database run db:push && pnpm --filter @colonels-academy/database run db:seed:direct && pnpm --filter @colonels-academy/api run seed:mock-test-bundles && pnpm --filter @colonels-academy/api run seed:asi-mock-tests && pnpm --filter @colonels-academy/api run seed:asi-questions && pnpm --filter @colonels-academy/api run seed:officer-cadet-questions && pnpm --filter @colonels-academy/api run seed:cadet-iq-test && node dist/index.cjs",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "seed:asi-mock-tests": "tsx src/scripts/seed-asi-mock-tests.ts",
    "seed:asi-questions": "tsx src/scripts/seed-asi-questions.ts",
    "seed:officer-cadet-questions": "tsx src/scripts/seed-officer-cadet-questions.ts",
    "seed:cadet-iq-test": "tsx src/scripts/seed-cadet-iq-test.ts",
    "seed:mock-test-bundles": "tsx src/scripts/seed-mock-test-bundles.ts"
  },
  "dependencies": {
    "@colonels-academy/config": "workspace:*",
    "@colonels-academy/contracts": "workspace:*",
    "@colonels-academy/database": "workspace:*",
    "@fastify/cookie": "^11.0.2",
    "@fastify/cors": "^10.0.1",
    "@fastify/helmet": "^13.0.1",
    "@fastify/rate-limit": "^10.3.0",
    "@fastify/sensible": "^6.0.3",
    "@prisma/client": "^6.19.3",
    "@sentry/node": "^10.50.0",
    "@sentry/profiling-node": "^10.50.0",
    "bullmq": "^5.46.1",
    "fastify": "^5.2.1",
    "fastify-plugin": "^5.0.1",
    "firebase-admin": "^13.1.0",
    "ioredis": "^5.4.2"
  },
  "devDependencies": {
    "@types/node": "^22.13.10",
    "@vitest/coverage-v8": "^2.1.8",
    "tsup": "^8.4.0",
    "tsx": "^4.19.3",
    "typescript": "^5.8.3",
    "vitest": "^2.1.8"
  }
}
