{
  "name": "@colonels-academy/api",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "tsx watch --env-file=../../.env src/index.ts",
    "build": "pnpm --filter @colonels-academy/database run db:generate && tsup --config tsup.config.ts",
    "start": "pnpm --filter @colonels-academy/database run db:push && npx tsx packages/database/prisma/seed.ts && node dist/index.cjs",
    "typecheck": "tsc --noEmit -p tsconfig.json"
  },
  "dependencies": {
    "@colonels-academy/config": "workspace:*",
    "@colonels-academy/contracts": "workspace:*",
    "@colonels-academy/database": "workspace:*",
    "@fastify/cookie": "^11.0.2",
    "@fastify/cors": "^10.0.1",
    "@fastify/helmet": "^13.0.1",
    "@fastify/rate-limit": "^10.3.0",
    "@fastify/sensible": "^6.0.3",
    "@prisma/client": "^6.19.3",
    "bullmq": "^5.46.1",
    "fastify": "^5.2.1",
    "fastify-plugin": "^5.0.1",
    "firebase-admin": "^13.1.0",
    "ioredis": "^5.4.2"
  },
  "devDependencies": {
    "@types/node": "^22.13.10",
    "tsup": "^8.4.0",
    "tsx": "^4.19.3",
    "typescript": "^5.8.3"
  }
}
