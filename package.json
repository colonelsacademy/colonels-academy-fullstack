{
  "name": "colonels-academy-fullstack",
  "private": true,
  "version": "0.1.0",
  "packageManager": "pnpm@10.33.0",
  "engines": {
    "node": ">=20.11.0",
    "pnpm": ">=10.0.0"
  },
  "scripts": {
    "dev": "docker compose up -d && node ./scripts/run-turbo.mjs dev --parallel --continue --filter=@colonels-academy/web --filter=@colonels-academy/api --filter=@colonels-academy/worker --filter=@colonels-academy/database",
    "dev:mobile": "node ./scripts/run-turbo.mjs dev --filter=@colonels-academy/mobile",
    "build": "node ./scripts/run-turbo.mjs build",
    "typecheck": "node ./scripts/run-turbo.mjs typecheck",
    "check:boundaries": "node ./scripts/check-boundaries.mjs",
    "validate": "pnpm run biome:check && pnpm run check:boundaries && pnpm run typecheck && pnpm run build",
    "db:generate": "pnpm --filter @colonels-academy/database run db:generate",
    "db:migrate": "pnpm --filter @colonels-academy/database run db:migrate",
    "db:deploy": "pnpm --filter @colonels-academy/database run db:deploy",
    "db:status": "pnpm --filter @colonels-academy/database run db:status",
    "db:push": "pnpm --filter @colonels-academy/database run db:push",
    "db:seed": "pnpm --filter @colonels-academy/database run db:seed",
    "db:studio": "pnpm --filter @colonels-academy/database run db:studio",
    "db:up": "docker compose up -d",
    "db:down": "docker compose down",
    "firebase:emulators": "firebase emulators:start --only auth",
    "biome:check": "biome check .",
    "biome:format": "biome format --write .",
    "prepare": "node -e \"console.log('Skipping git hooks setup on Windows for now.')\""
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "@firebase/util",
      "@prisma/client",
      "@prisma/engines",
      "esbuild",
      "msgpackr-extract",
      "prisma",
      "protobufjs",
      "sharp"
    ]
  },
  "devDependencies": {
    "@biomejs/biome": "1.9.4",
    "dotenv": "^16.5.0",
    "firebase-tools": "^14.0.0",
    "turbo": "^2.5.3"
  }
}
