# -----------------------------------------------------------------------------
# COLONELS ACADEMY - DEV DEPLOYMENT ENVIRONMENT TEMPLATE
# -----------------------------------------------------------------------------
# Copy this file to .env on your hosting platform and fill in the real values.
# This targets: https://dev.thecolonelsacademy.com (Bunny.net Pull Zone)

NODE_ENV="production"

# --- DATABASE ---
DATABASE_URL="postgres://..."

# --- REDIS ---
REDIS_URL="redis://..."

# --- API CONFIG ---
API_HOST="0.0.0.0"
API_PORT="4000"
# Public-facing origin — must match the Bunny Pull Zone hostname
WEB_ORIGIN="https://dev.thecolonelsacademy.com"
LOG_LEVEL="info"
# Required: app sits behind Bunny.net reverse proxy
API_TRUST_PROXY="true"
API_RATE_LIMIT_MAX="100"
API_RATE_LIMIT_WINDOW="1 minute"
WORKER_CONCURRENCY="5"

# --- SESSION & CSRF ---
SESSION_COOKIE_NAME="ca_session"
# Required: share cookie across web + api subdomains
SESSION_COOKIE_DOMAIN=".thecolonelsacademy.com"
SESSION_COOKIE_SECURE="true"
SESSION_MAX_AGE_DAYS="5"
SESSION_RECENT_SIGN_IN_MINUTES="5"
CSRF_COOKIE_NAME="ca_csrf"
CSRF_TOKEN_MAX_AGE_MINUTES="60"

# --- SEED CONTROL ---
SEED_RESET_LIVE_SESSIONS="false"

# --- AUTH (FIREBASE ADMIN) ---
FIREBASE_CHECK_REVOKED_SESSIONS="true"
FIREBASE_PROJECT_ID="colonels-academy-dev"
FIREBASE_CLIENT_EMAIL="firebase-adminsdk-...@colonels-academy-dev.iam.gserviceaccount.com"
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"

# --- BUNNY CDN ---
# Both server-side and client-side vars must point to the branded domain.
# The AssetService in packages/config/src/assets.ts reads these to resolve all
# course and instructor image URLs automatically.
BUNNY_CDN_URL="https://dev.thecolonelsacademy.com"
BUNNY_STORAGE_NAME="colonels-academy-assets"
BUNNY_STORAGE_PASSWORD="your-bunny-storage-password"

# --- BUNNY STREAM ---
BUNNY_STREAM_LIBRARY_ID="596237"
BUNNY_STREAM_API_KEY="your-bunny-stream-api-key"
BUNNY_STREAM_PULL_ZONE="your-stream-pull-zone"
# Video delivery hostname (separate from image CDN)
BUNNY_STREAM_CDN_HOSTNAME="dev.thecolonelsacademy.com"

# --- NEXT.js PUBLIC VARS ---
# Must be set at build time — baked into the client bundle.
# NOTE: Also update the GitHub Secret NEXT_PUBLIC_BUNNY_CDN_URL in:
# GitHub → Settings → Secrets → Actions
NEXT_PUBLIC_API_BASE_URL="https://dev.thecolonelsacademy.com/api"
NEXT_PUBLIC_BUNNY_CDN_URL="https://dev.thecolonelsacademy.com"
NEXT_PUBLIC_USE_FIREBASE_EMULATOR="false"
NEXT_PUBLIC_FIREBASE_API_KEY="your-firebase-api-key"
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN="colonels-academy-dev.firebaseapp.com"
NEXT_PUBLIC_FIREBASE_PROJECT_ID="colonels-academy-dev"
NEXT_PUBLIC_FIREBASE_APP_ID="1:..."
