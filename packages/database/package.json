{
  "name": "@colonels-academy/database",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "exports": {
    ".": "./src/index.ts"
  },
  "scripts": {
    "postinstall": "prisma generate",
    "dev": "prisma studio",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev",
