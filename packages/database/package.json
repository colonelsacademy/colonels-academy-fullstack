  },
  "prisma": {
    "seed": "tsx ./prisma/seed.ts"
  },
  "dependencies": {
    "@colonels-academy/contracts": "workspace:*",
    "@prisma/client": "^6.19.3"
  },
  "devDependencies": {
    "@types/node": "^22.13.10",
    "dotenv": "^16.5.0",
    "prisma": "^6.19.3",
    "tsx": "^4.19.3",
    "typescript": "^5.8.3"
  }
}
