generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  STUDENT
  INSTRUCTOR
  DS
  ADMIN
}

enum ProgressStatus {
  NOT_STARTED
  IN_PROGRESS
  COMPLETED
}

enum EnrollmentStatus {
  PENDING
  ACTIVE
  EXPIRED
  REFUNDED
}

enum LessonAccessKind {
  PREVIEW
  STANDARD
  LIVE_REPLAY
  DOWNLOADABLE
}

enum ContentType {
  VIDEO
  PDF
  LIVE
  QUIZ
  TEXT
}

enum VideoAssetStatus {
  DRAFT
  UPLOADING
  PROCESSING
  READY
  FAILED
}

enum AttendanceMode {
  LIVE_ONLY
  LIVE_AND_REPLAY
  REPLAY_ONLY
}

enum OrderStatus {
  DRAFT
  PENDING_PAYMENT
  PAID
  FAILED
  REFUNDED
}

model User {
  id          String         @id @default(cuid())
  firebaseUid String         @unique
  email       String?        @unique
  displayName String?
  role        UserRole       @default(STUDENT)
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt
  enrollments Enrollment[]
  orders      PurchaseOrder[]
  progress    UserProgress[]
  cadetIqMockResults CadetIqMockResult[]
  quizSessions QuizSession[]
  quizAttempts QuizAttempt[]
}

/// Cadet IQ / mock assessment attempts (stored in Postgres; replaces legacy Firestore collection).
model CadetIqMockResult {
  id          String   @id @default(cuid())
  userId      String
  score       Int?
  totalMarks  Int?
  timeTaken   Int?
  passed      Boolean?
  answers     Json     @default("{}")
  isCleared   Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, isCleared, createdAt(sort: Desc)])
}

model Instructor {
  id              String             @id @default(cuid())
  slug            String             @unique
  name            String
  branch          String
  experienceLabel String
  specialization  String
  bio             String             @db.Text
  avatarUrl       String?
  createdAt       DateTime           @default(now())
  updatedAt       DateTime           @updatedAt
  courseLinks     CourseInstructor[]
}

model Course {
  id               String             @id @default(cuid())
  slug             String             @unique
  title            String
  track            String
  summary          String
  description      String             @db.Text
  level            String
  durationLabel    String
  lessonCount      Int
  priceNpr         Int
  originalPriceNpr Int?
  accentColor      String
  heroImageUrl     String?
  isFeatured       Boolean            @default(false)
  isComingSoon     Boolean            @default(false)
  createdAt        DateTime           @default(now())
  updatedAt        DateTime           @updatedAt
  instructorLinks  CourseInstructor[]
  modules          Module[]
  lessons          Lesson[]
  enrollments      Enrollment[]
  liveSessions     LiveSession[]
  videoAssets      VideoAsset[]
  orderItems       PurchaseOrderItem[]
  userProgress     UserProgress[]
  quizSessions     QuizSession[]
  quizAttempts     QuizAttempt[]
}

model Module {
  id        String   @id @default(cuid())
  courseId  String
  title     String
  position  Int
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  course    Course   @relation(fields: [courseId], references: [id], onDelete: Cascade)
  lessons   Lesson[]

  @@unique([courseId, position])
}

model CourseInstructor {
  courseId     String
  instructorId String
  displayOrder Int        @default(0)
  course       Course     @relation(fields: [courseId], references: [id], onDelete: Cascade)
  instructor   Instructor @relation(fields: [instructorId], references: [id], onDelete: Cascade)

  @@id([courseId, instructorId])
}

model Lesson {
  id              String           @id @default(cuid())
  courseId        String
  moduleId        String?
  prerequisiteId  String?          // The lesson that must be COMPLETED before this one
  title           String
  synopsis        String
  position        Int
  durationMinutes Int?
  contentType     ContentType      @default(VIDEO)
  accessKind      LessonAccessKind @default(STANDARD)
  bunnyVideoId    String?
  videoAssetId    String?
  meetingUrl      String?
  pdfUrl          String?
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  course          Course           @relation(fields: [courseId], references: [id], onDelete: Cascade)
  module          Module?          @relation(fields: [moduleId], references: [id], onDelete: SetNull)
  videoAsset      VideoAsset?      @relation(fields: [videoAssetId], references: [id])
  quizQuestions   QuizQuestion[]
  prerequisite    Lesson?          @relation("LessonPrerequisite", fields: [prerequisiteId], references: [id], onDelete: SetNull)
  dependants      Lesson[]         @relation("LessonPrerequisite")
  userProgress    UserProgress[]
  quizAttempts    QuizAttempt[]

  @@unique([courseId, position])
}

model QuizQuestion {
  id                 String   @id @default(cuid())
  lessonId           String
  question           String
  options            Json
  correctOptionIndex Int
  explanation        String?
  position           Int
  difficulty         Int      @default(1) // 1–5 scale
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
  lesson             Lesson   @relation(fields: [lessonId], references: [id], onDelete: Cascade)
  attempts           QuizAttempt[]

  @@unique([lessonId, position])
}

model Enrollment {
  id              String           @id @default(cuid())
  userId          String
  courseId        String
  status          EnrollmentStatus @default(ACTIVE)
  progressPercent Int              @default(0)
  purchasedAt     DateTime         @default(now())
  expiresAt       DateTime?
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  user            User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  course          Course           @relation(fields: [courseId], references: [id], onDelete: Cascade)

  @@unique([userId, courseId])
}

model VideoAsset {
  id             String           @id @default(cuid())
  courseId       String?
  libraryId      String
  bunnyVideoId   String           @unique
  title          String
  status         VideoAssetStatus @default(UPLOADING)
  playbackUrl    String?
  thumbnailUrl   String?
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt
  course         Course?          @relation(fields: [courseId], references: [id], onDelete: SetNull)
  lessons        Lesson[]
  replaySessions LiveSession[]
}

model LiveSession {
  id                 String         @id @default(cuid())
  courseId           String
  title              String
  startsAt           DateTime
  endsAt             DateTime
  deliveryMode       String
  attendanceMode     AttendanceMode @default(LIVE_AND_REPLAY)
  meetingUrl         String?
  replayVideoAssetId String?
  createdAt          DateTime       @default(now())
  updatedAt          DateTime       @updatedAt
  course             Course         @relation(fields: [courseId], references: [id], onDelete: Cascade)
  replayVideoAsset   VideoAsset?    @relation(fields: [replayVideoAssetId], references: [id], onDelete: SetNull)
}

model PurchaseOrder {
  id        String              @id @default(cuid())
  userId    String
  status    OrderStatus         @default(DRAFT)
  totalNpr  Int
  currency  String              @default("NPR")
  provider  String?
  createdAt DateTime            @default(now())
  updatedAt DateTime            @updatedAt
  user      User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  items     PurchaseOrderItem[]
}

model PurchaseOrderItem {
  id        String        @id @default(cuid())
  orderId   String
  courseId  String
  priceNpr  Int
  quantity  Int           @default(1)
  createdAt DateTime      @default(now())
  order     PurchaseOrder @relation(fields: [orderId], references: [id], onDelete: Cascade)
  course    Course        @relation(fields: [courseId], references: [id], onDelete: Restrict)
}

model UserProgress {
  id          String         @id @default(cuid())
  userId      String
  lessonId    String
  courseId    String
  status      ProgressStatus @default(NOT_STARTED)
  startedAt   DateTime?
  completedAt DateTime?
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt

  user   User   @relation(fields: [userId],   references: [id], onDelete: Cascade)
  lesson Lesson @relation(fields: [lessonId], references: [id], onDelete: Cascade)
  course Course @relation(fields: [courseId], references: [id], onDelete: Cascade)

  @@unique([userId, lessonId])
  @@index([userId, courseId])
}

enum QuizSessionKind {
  PRACTICE
  WEEKLY_DRILL
  MOCK_EXAM
}

model QuizSession {
  id         String          @id @default(cuid())
  userId     String
  courseId   String
  kind       QuizSessionKind @default(PRACTICE)
  startedAt  DateTime        @default(now())
  finishedAt DateTime?
  user       User            @relation(fields: [userId],   references: [id], onDelete: Cascade)
  course     Course          @relation(fields: [courseId], references: [id], onDelete: Cascade)
  attempts   QuizAttempt[]

  @@index([userId, courseId])
}

model QuizAttempt {
  id                  String       @id @default(cuid())
  userId              String
  questionId          String
  lessonId            String
  courseId            String
  sessionId           String?      // nullable — standalone practice attempts need no session
  selectedOptionIndex Int
  isCorrect           Boolean
  timeTakenMs         Int
  difficultySnapshot  Int          // value of QuizQuestion.difficulty at attempt time
  attemptedAt         DateTime     @default(now())

  user     User         @relation(fields: [userId],     references: [id], onDelete: Cascade)
  question QuizQuestion @relation(fields: [questionId], references: [id], onDelete: Cascade)
  lesson   Lesson       @relation(fields: [lessonId],   references: [id], onDelete: Cascade)
  course   Course       @relation(fields: [courseId],   references: [id], onDelete: Cascade)
  session  QuizSession? @relation(fields: [sessionId],  references: [id], onDelete: SetNull)

  @@index([userId, courseId])
  @@index([userId, lessonId])
}
