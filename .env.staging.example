# -----------------------------------------------------------------------------
# COLONELS ACADEMY - STAGING ENVIRONMENT TEMPLATE
# -----------------------------------------------------------------------------
# Copy this file to .env in your staging environment and fill in the real values.

NODE_ENV="production"

# --- DATABASE ---
# Format: postgres://USER:PASSWORD@HOST:PORT/DATABASE
DATABASE_URL="postgres://..."

# --- REDIS ---
# Format: redis://HOST:PORT
REDIS_URL="redis://..."

# --- API CONFIG ---
API_HOST="0.0.0.0"
API_PORT="4000"
WEB_ORIGIN="https://staging.thecolonelsacademy.com"
LOG_LEVEL="info"
# Required: staging sits behind a reverse proxy/load balancer
API_TRUST_PROXY="true"
API_RATE_LIMIT_MAX="100"
API_RATE_LIMIT_WINDOW="1 minute"

# --- SESSION & CSRF ---
SESSION_COOKIE_NAME="ca_session"
# Required: share the cookie across web + api subdomains
SESSION_COOKIE_DOMAIN=".thecolonelsacademy.com"
SESSION_COOKIE_SECURE="true"
SESSION_MAX_AGE_DAYS="5"
CSRF_COOKIE_NAME="ca_csrf"

# --- SEED CONTROL ---
# Set to "true" only when you intentionally want to wipe live sessions during seed
SEED_RESET_LIVE_SESSIONS="false"

# --- AUTH (FIREBASE ADMIN) ---
# Required for API to verify session tokens
FIREBASE_PROJECT_ID="your-staging-project-id"
FIREBASE_CLIENT_EMAIL="firebase-adminsdk-...@..."
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"

# --- BUNNY STREAM ---
# Required for video processing and CDN delivery
BUNNY_STREAM_LIBRARY_ID="your-staging-library-id"
BUNNY_STREAM_API_KEY="your-staging-api-key"
BUNNY_STREAM_PULL_ZONE="your-staging-pull-zone"
BUNNY_STREAM_CDN_HOSTNAME="staging-assets.b-cdn.net"

# --- NEXT.js PUBLIC VARS ---
# Must be available at build time
NEXT_PUBLIC_API_BASE_URL="https://staging-api.thecolonelsacademy.com"
NEXT_PUBLIC_FIREBASE_API_KEY="your-staging-api-key"
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN="staging-project.firebaseapp.com"
NEXT_PUBLIC_FIREBASE_PROJECT_ID="your-staging-project-id"
NEXT_PUBLIC_FIREBASE_APP_ID="1:..."
